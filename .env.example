# ─────────────────────────────────────────────────────────────
#  mcintel — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_ENV=development            # development | production | test
APP_DEBUG=false
APP_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_LOG_FORMAT=text            # text | json

# ── Database ──────────────────────────────────────────────────
# SQLite (default for development — just leave the path)
DATABASE_URL=sqlite+aiosqlite:///./data/mcintel.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mcintel

# ── Redis (optional — used for caching & task queue) ──────────
REDIS_URL=redis://localhost:6379/0

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true                # Set to false in production
API_SECRET_KEY=change-me-to-a-long-random-string
API_ALLOWED_ORIGINS=http://localhost:3000,https://mcin.tel

# ── Rate Limiting (politeness layer) ──────────────────────────
# Delay between successive pings to the same server (seconds)
SCAN_PING_INTERVAL=300         # 5 minutes
# Max concurrent TCP connections during scanning
SCAN_MAX_CONCURRENCY=50
# TCP connect / read timeout (seconds)
SCAN_TIMEOUT=5

# ── Scheduler ─────────────────────────────────────────────────
SCHEDULER_ENABLED=true
# Cron expression for the default server re-ping job
SCHEDULER_PING_CRON=*/15 * * * *

# ── IP Intelligence (ipinfo.io) ───────────────────────────────
# Free tier: 50 000 req/month — get a token at https://ipinfo.io/signup
IPINFO_TOKEN=

# ── Shodan (Phase 6 — mass recon) ─────────────────────────────
# https://account.shodan.io/
SHODAN_API_KEY=

# ── Censys (Phase 6 — mass recon) ─────────────────────────────
# https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── NameMC (Phase 4 — player intelligence) ────────────────────
# No official API key required; set a custom User-Agent
NAMEMC_USER_AGENT=mcintel/0.1 (https://mcin.tel; research)

# ── Mojang API ────────────────────────────────────────────────
# No key required for public endpoints; adjust rate limits if needed
MOJANG_RATE_LIMIT=600          # requests per 10 minutes (Mojang default)

# ── Data Retention ────────────────────────────────────────────
# How many days to keep raw ping records before pruning (-1 = forever)
RETENTION_PING_DAYS=90
# How many days to keep DNS history records (-1 = forever)
RETENTION_DNS_DAYS=365

# ── Opt-out ───────────────────────────────────────────────────
# Path to a plain-text file listing IPs/domains that have opted out
OPTOUT_LIST_PATH=./data/optout.txt
